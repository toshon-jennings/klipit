{
  "manifest_version": 3,
  "name": "Klipit",
  "version": "0.4.3",
  "description": "One-click link memory with context. Save links, jot notes, and connect related ideas — no friction, no backend.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "tabs", "activeTab", "sidePanel", "contextMenus"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Klipit — open side panel",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "commands": {
    "save-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save the current page to Klipit"
    }
  }
}
