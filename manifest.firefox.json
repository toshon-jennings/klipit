{
  "manifest_version": 3,
  "name": "Klipit",
  "version": "0.4.3",
  "description": "One-click link memory with context. Save links, jot notes, and connect related ideas — no friction, no backend.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "klippit@toshon.tech",
      "strict_min_version": "115.0"
    }
  },
  "permissions": ["storage", "tabs", "activeTab", "contextMenus"],
  "background": {
    "scripts": ["vendor/browser-polyfill.min.js", "src/background.js"]
  },
  "action": {
    "default_title": "Klipit — open sidebar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "sidebar_action": {
    "default_title": "Klipit",
    "default_panel": "src/sidepanel.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "commands": {
    "save-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save the current page to Klipit"
    }
  }
}
